# ============================================================
# ARTIX MEDIA — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ---- Supabase (Frontend) ----
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ---- Cloudflare Turnstile (Frontend) ----
# Get from: dash.cloudflare.com → Turnstile → Add site
# Widget type: Managed | Domain: artixmedia.in
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# ============================================================
# Supabase Edge Function Secrets
# Add via: Supabase Dashboard → Edge Functions → Secrets
# OR: supabase secrets set KEY=value
# ============================================================

# Discord Webhooks
LEADS_WEBHOOK_URL=https://discord.com/api/webhooks/...
FEEDBACK_WEBHOOK_URL=https://discord.com/api/webhooks/...
SYSTEM_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Resend Email
RESEND_API_KEY=re_...
NOTIFICATION_EMAIL=you@yourdomain.com

# Cloudflare Turnstile (Server-side secret)
# Get from: dash.cloudflare.com → Turnstile → your site → Secret key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Supabase Service Role (auto-available in Edge Functions)
# SUPABASE_URL          → auto-injected by Supabase runtime
# SUPABASE_SERVICE_ROLE_KEY → auto-injected by Supabase runtime
